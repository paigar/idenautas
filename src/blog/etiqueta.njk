---
layout: layouts/page.njk
pagination:
  data: etiquetas
  size: 1
  alias: etiquetaSlug
  resolve: keys
permalink: /blog/{{ etiquetaSlug }}/
eleventyExcludeFromCollections: true
eleventyComputed:
  title: "{{ etiquetas[etiquetaSlug].nombre }}"
  label: "Blog"
  subtitle: "{{ etiquetas[etiquetaSlug].descripcion }}"
  heroImage: "{{ etiquetas[etiquetaSlug].heroImage }}"
  description: "{{ etiquetas[etiquetaSlug].descripcion }}"
---

<section class="section svc-section--alt" style="padding-block: var(--space-sm);">
  <div class="container">
    <div class="tag-filter">
      <span class="tag-filter__label">Artículos etiquetados como</span>
      <span class="tag-filter__wrap">
        <select class="tag-filter__select" onchange="window.location.href=this.value" aria-label="Filtrar por etiqueta">
          <option value="/blog/">Todos</option>
          {%- for slug, data in etiquetas %}
            <option value="/blog/{{ slug }}/"{% if slug == etiquetaSlug %} selected{% endif %}>{{ data.nombre }}</option>
          {%- endfor %}
        </select>
      </span>
    </div>
  </div>
</section>

<section class="section" style="padding-top: var(--space-lg);">
  <div class="container">
    <div class="blog-grid">
      {%- set tagPosts = collections[etiquetaSlug] %}
      {%- for post in tagPosts | reverse %}
        {%- set isFeatured = loop.first %}
        {%- set isWide = (not loop.first) and (loop.index0 % 9 == 0) %}
        <article class="blog-card{% if isFeatured %} blog-card--featured{% elif isWide %} blog-card--wide{% endif %}" data-reveal>
          <a href="{{ post.url }}" class="blog-card__link">
            <div class="blog-card__img">
              {%- set cardImg = post.data.heroImage or 'idenautas-web/general.png' -%}
              <div class="lqip-wrap" style="background-image:url('{{ cardImg | lqip }}')">
                <img src="{{ site.cdn }}{{ cardImg }}?width={% if isFeatured or isWide %}800{% else %}400{% endif %}&quality=60"
                     alt="{{ post.data.alt or '' }}"
                     loading="{% if isFeatured %}eager{% else %}lazy{% endif %}"
                     width="{% if isFeatured or isWide %}800{% else %}400{% endif %}" height="{% if isFeatured or isWide %}450{% else %}225{% endif %}"
                     onload="this.parentNode.classList.add('loaded')">
              </div>
            </div>
            <div class="blog-card__content">
              <h2 class="blog-card__title">{{ post.data.title }}</h2>
              {% if post.data.description %}
                <p class="blog-card__excerpt">{{ post.data.description }}</p>
              {% endif %}
              <span class="blog-card__read">Leer artículo <span aria-hidden="true">→</span></span>
            </div>
          </a>
        </article>
      {%- endfor %}
    </div>
  </div>
</section>