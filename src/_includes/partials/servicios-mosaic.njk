{# ── Services Mosaic (partial) ────────────────────────────── #}
{# En subpáginas de servicio, ocultamos la tarjeta del servicio actual.
   Las 4 restantes ocupan siempre las posiciones 1–4 del grid (sin huecos).
   La posición 5 y la imagen 3 solo se muestran cuando están las 5 tarjetas. #}

{% set isSubpage = (
  page.url == "/servicios/desarrollo-web/" or
  page.url == "/servicios/identidad-corporativa/" or
  page.url == "/servicios/mantenimiento-web/" or
  page.url == "/servicios/gestion-contenidos/" or
  page.url == "/servicios/alojamiento-web/"
) %}

{% set pos = 1 %}

<div class="services-mosaic">

  {# ── Card: Desarrollo web ─── #}
  {% if page.url != "/servicios/desarrollo-web/" %}
  <article class="service-card service-card--{{ pos }}" data-reveal>
    <span class="service-card__number" aria-hidden="true">01</span>
    <div class="service-card__content">
      <h3 class="service-card__title">Desarrollo web</h3>
      <p class="service-card__text">
        Creamos sitios web y aplicaciones a medida, sin plantillas y con código optimizado.
        Desde webs corporativas hasta soluciones técnicas complejas, elegimos la tecnología
        que mejor se adapta a cada proyecto.
      </p>
      <a href="/servicios/desarrollo-web/" class="svc-card-link">Saber más <span>→</span></a>
    </div>
  </article>
  {% set pos = pos + 1 %}
  {% endif %}

  {# ── Image 1 ─── #}
  <div class="service-img service-img--1" data-reveal data-reveal-delay="0.15">
    {% img "idenautas-web/nosotros_02.png", "Equipo Idenautas trabajando", "mosaic" %}
  </div>

  {# ── Card: Mantenimiento web ─── #}
  {% if page.url != "/servicios/mantenimiento-web/" %}
  <article class="service-card service-card--{{ pos }}" data-reveal data-reveal-delay="0.2">
    <span class="service-card__number" aria-hidden="true">02</span>
    <div class="service-card__content">
      <h3 class="service-card__title">Mantenimiento web</h3>
      <p class="service-card__text">
        Una web publicada no es una web terminada. Nos encargamos de que tu presencia online
        siga funcionando correctamente: seguridad, actualizaciones, rendimiento y monitorización constante.
      </p>
      <a href="/servicios/mantenimiento-web/" class="svc-card-link">Saber más <span>→</span></a>
    </div>
  </article>
  {% set pos = pos + 1 %}
  {% endif %}

  {# ── Image 2 ─── #}
  <div class="service-img service-img--2" data-reveal data-reveal-delay="0.1">
    {% img "idenautas-web/nosotros_03.png", "Proceso creativo de diseño web", "mosaic" %}
  </div>

  {# ── Card: Identidad corporativa ─── #}
  {% if page.url != "/servicios/identidad-corporativa/" %}
  <article class="service-card service-card--{{ pos }}" data-reveal data-reveal-delay="0.15">
    <span class="service-card__number" aria-hidden="true">03</span>
    <div class="service-card__content">
      <h3 class="service-card__title">Identidad corporativa</h3>
      <p class="service-card__text">
        El logotipo y la imagen gráfica de un proyecto son mucho más que estética: son la primera
        impresión. Ayudamos a definir y construir identidades visuales coherentes, originales
        y adaptadas al público objetivo.
      </p>
      <a href="/servicios/identidad-corporativa/" class="svc-card-link">Saber más <span>→</span></a>
    </div>
  </article>
  {% set pos = pos + 1 %}
  {% endif %}

  {# ── Card: Gestión de contenidos ─── #}
  {% if page.url != "/servicios/gestion-contenidos/" %}
  <article class="service-card service-card--{{ pos }}" data-reveal data-reveal-delay="0.2">
    <span class="service-card__number" aria-hidden="true">04</span>
    <div class="service-card__content">
      <h3 class="service-card__title">Gestión de contenidos</h3>
      <p class="service-card__text">
        El contenido de una web es lo que la hace encontrable y lo que convence a quien llega.
        Redactamos y gestionamos los textos teniendo en cuenta la audiencia, el tono de la marca
        y los criterios de posicionamiento orgánico.
      </p>
      <a href="/servicios/gestion-contenidos/" class="svc-card-link">Saber más <span>→</span></a>
    </div>
  </article>
  {% set pos = pos + 1 %}
  {% endif %}

  {# ── Card: Alojamiento ─── #}
  {% if page.url != "/servicios/alojamiento-web/" %}
  <article class="service-card service-card--{{ pos }}" data-reveal data-reveal-delay="0.1">
    <span class="service-card__number" aria-hidden="true">05</span>
    <div class="service-card__content">
      <h3 class="service-card__title">Alojamiento web y dominios</h3>
      <p class="service-card__text">
        Gestionamos el alojamiento en servidores optimizados, sin sobredimensionamientos
        ni recursos innecesarios. También nos ocupamos del registro y renovación de dominios.
      </p>
      <a href="/servicios/alojamiento-web/" class="svc-card-link">Saber más <span>→</span></a>
    </div>
  </article>
  {% endif %}

  {# ── Image 3: solo cuando se muestran las 5 tarjetas ─── #}
  {% if not isSubpage %}
  <div class="service-img service-img--3" data-reveal data-reveal-delay="0.25">
    {% img "idenautas-web/nosotros_04.png", "Tecnología y desarrollo digital", "mosaic" %}
  </div>
  {% endif %}

</div>
