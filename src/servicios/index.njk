    <div class="home-services__header" style="margin-bottom: var(--space-lg)">
      <div data-reveal>
        <p class="text-xs uppercase text-accent font-display" style="margin-bottom: var(--space-sm)">Servicios</p>
        <h2 class="text-2xl">Qué hacemos</h2>
